{
  "name": "jarvis-mc",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript SDK for Jarvis Mission Control — connect any agent to your dashboard in a few lines",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["jarvis", "agent", "ai", "mission-control", "llm"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
